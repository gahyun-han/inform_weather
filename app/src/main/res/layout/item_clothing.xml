<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/card_background">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="160dp">

        <!-- Clothing image -->
        <ImageView
            android:id="@+id/ivClothingThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/image_background"
            android:contentDescription="옷 사진"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_clothing_placeholder" />

        <!-- Category badge (bottom-left) -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:background="@drawable/bg_category_tag"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textSize="11sp"
            android:textColor="@color/primary"
            tools:text="아우터" />

        <!-- Delete button (top-right) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabDeleteClothing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            app:fabSize="mini"
            app:srcCompat="@drawable/ic_remove"
            android:contentDescription="삭제"
            android:backgroundTint="#CCF44336"
            app:tint="@color/white" />

    </FrameLayout>

</androidx.cardview.widget.CardView>
